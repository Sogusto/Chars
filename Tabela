-- Função para validar se o jogador pode usar um personagem
Tabela.CanUseCharacter = function(playerName, characterName)
	local playerData = Tabela.PlayerPermission[playerName]
	local characterData = Tabela.Characters[characterName]
	
	if not playerData or not characterData then
		return false, "Jogador ou personagem não existe"
	end
	
	-- Verifica se o tier do jogador é suficiente
	if playerData.PlayerTier < characterData.Tier then
		return false, "Tier insuficiente"
	end
	
	-- Verifica se há restrição de jogador específico
	if #characterData.PlayersPermission > 0 then
		local hasPermission = false
		for _, userId in ipairs(characterData.PlayersPermission) do
			if userId == playerName then
				hasPermission = true
				break
			end
		end
		if not hasPermission then
			return false, "Sem permissão para este personagem"
		end
	end
	
	return true, "Permissão concedida"
end

Tabela.TrocarPersonagem = function(args)
	local Parent = script.Parent
	local Player = args.Player
	
	-- Validar permissão antes de enviar
	local canUse, message = Tabela.CanUseCharacter(Player.Name, args.char)
	
	if not canUse then
		print("Erro ao trocar personagem: " .. message)
		return
	end
	
	-- Buscar o evento
	local Event = game.ReplicatedStorage:WaitForChild("ChangeCharacter")
	
	-- Enviar dados corretos
	Event:FireServer({
		char = args.char,
		CharacterData = Tabela.Characters[args.char],
		PlayerTier = Tabela.PlayerPermission[Player.Name].PlayerTier,
		Player = Player
	})
	
	Parent.Parent.Visible = false
end

return Tabela
